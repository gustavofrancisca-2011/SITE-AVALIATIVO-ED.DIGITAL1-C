HTML

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EcoTech | Inovação Sustentável</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <header role="banner">
        <nav class="navbar" aria-label="Menu Principal">
            <div class="logo">EcoTech</div>
            <div class="accessibility-controls">
                <button id="btn-contrast" aria-label="Alternar Alto Contraste">🌓</button>
                <button id="btn-font-plus" aria-label="Aumentar Fonte">A+</button>
                <button id="btn-font-minus" aria-label="Diminuir Fonte">A-</button>
            </div>
        </nav>
    </header>

    <main id="main-content">
        <section class="hero" aria-labelledby="hero-title">
            <div class="container">
                <h1 id="hero-title">O futuro da tecnologia é verde.</h1>
                <p>Soluções inteligentes para um planeta em equilíbrio.</p>
                <a href="#services" class="btn-primary">Saiba Mais</a>
            </div>
        </section>

        <section id="services" class="reveal" aria-labelledby="services-title">
            <div class="container">
                <h2 id="services-title">Nossos Serviços</h2>
                <div id="services-grid" class="grid-layout">
                    </div>
            </div>
        </section>

        <section class="faq reveal" aria-labelledby="faq-title">
            <div class="container">
                <h2 id="faq-title">Dúvidas Frequentes</h2>
                <div id="faq-container">
                    </div>
            </div>
        </section>
    </main>

    <footer role="contentinfo">
        <p>&copy; 2024 EcoTech. Desenvolvido com foco em acessibilidade.</p>
    </footer>

    <script src="script.js"></script>
</body>
</html>
